# Copy to .env and fill in.
# Get these from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Your numeric chat id. After your bot is created, send it any
# message in Telegram, then fetch:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy the `message.chat.id` value from the JSON response.
TELEGRAM_CHAT_ID=
